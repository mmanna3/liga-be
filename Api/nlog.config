<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-interno.log">

	<extensions>
		<add assembly="NLog.Web.AspNetCore"/>
	</extensions>

	<targets>
		<target xsi:type="File" name="allfile" fileName="${basedir}/logs/nlog-all-${shortdate}.log"
		        archiveAboveSize="5242880"
		        maxArchiveFiles="7"
		        layout="${longdate}|${uppercase:${level}}|${logger}|${message} ${exception:format=tostring}" />

		<target xsi:type="File" name="ownFile-web" fileName="${basedir}/logs/nlog-api-${shortdate}.log"
		        archiveAboveSize="5242880"
		        maxArchiveFiles="7"
		        layout="${longdate}|${uppercase:${level}}|${logger}|${message} ${exception:format=tostring}|url: ${aspnet-request-url}|action: ${aspnet-mvc-action}" />

		<target xsi:type="Console" name="lifetimeConsole" layout="${MicrosoftConsoleLayout}" />
	</targets>

	<rules>
		<!-- Consola: solo arranque / parada del host (útil en Docker / IDE). -->
		<logger name="Microsoft.Hosting.*" minlevel="Info" writeTo="lifetimeConsole" final="true" />

		<!--
		  Disco: NO registrar Trace/Debug/Info del stack Microsoft/System (Kestrel, routing,
		  cada request, CORS preflight, etc.). Eso era lo que inflaba los archivos.
		  Solo Warning+ de framework y Error+ del resto (incluye tu código y fallos no capturados).
		-->
		<logger name="Microsoft.*" minlevel="Warn" writeTo="allfile,ownFile-web" final="true" />
		<logger name="System.*" minlevel="Warn" writeTo="allfile,ownFile-web" final="true" />

		<logger name="*" minlevel="Error" writeTo="allfile,ownFile-web" />
	</rules>
</nlog>
